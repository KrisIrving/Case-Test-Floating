FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Type of mesh generation:
//  - castellated (default)
//  - castellatedBufferLayer
//type            castellatedBufferLayer;


// Which of the steps to run
castellatedMesh true;
snap            true;
addLayers       false;

geometry
{
    floatingObject.stl
    {
        type triSurfaceMesh;
        name floatingObject; // ! add
    }
};

// Settings for the castellatedMesh generation.
castellatedMeshControls
{

    maxLocalCells 100000;
    maxGlobalCells 2000000;
    minRefinementCells 0;
    maxLoadUnbalance 0.10;

    nCellsBetweenLevels 2; // ? original is 1

    features // 几何特征
    (
        {
            file "floatingObject.eMesh";
            level 2;        // Have level 2 for all cells intersected
                             // by feature.
            //levels ((0.1 2)); // Have level 2 for all cells within
                             // 0.1 of feature.
        }
    );

    refinementSurfaces // 指定被处理的几何体
    {
        floatingObject
        {
            // Surface-wise min and max refinement level
            level (2 2);
            patchInfo
            {
                type wall;
                inGroups (floatGroup); // todo
            }
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
    }

    limitRegions
    {
    }
    locationInMesh (0.25 0.25 0.15);
    allowFreeStandingZoneFaces true;
}

// 控制网格节点的移动
snapControls
{
    nSmoothPatch 3;
    tolerance 2.0;
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

// Settings for the layer addition.
addLayersControls
{
    relativeSizes true;
    expansionRatio 1.0;
    finalLayerThickness 0.3;
    minThickness 0.1;
    layers
    {
        "(floatingObject).*"
        {
            nSurfaceLayers 3;
        }
    }

    nGrow 0;
    featureAngle 30;
    maxFaceThicknessRatio 0.5;
    nSmoothSurfaceNormals 1;
    nSmoothThickness 5;
    minMedialAxisAngle 90;
    maxThicknessToMedialRatio 0.3;
    nSmoothNormals 3;
    slipFeatureAngle 30;
    nRelaxIter 3;
    nBufferCellsNoExtrude 0;
    nLayerIter 5;
    nRelaxedIter 20;
}

// Generic mesh quality settings. At any undoable phase these determine
// where to undo.
meshQualityControls
{
    // Specify mesh quality constraints in separate dictionary so can
    // be reused (e.g. checkMesh -meshQuality)
    #include "meshQualityDict"


    // Optional : some meshing phases allow usage of relaxed rules.
    // See e.g. addLayersControls::nRelaxedIter.
    relaxed
    {
        // Maximum non-orthogonality allowed. Set to 180 to disable.
        maxNonOrtho 75;
    }


    // Advanced

        // Number of error distribution iterations
        nSmoothScale 4;
        // amount to scale back displacement at error points
        errorReduction 0.75;
}

writeFlags
(
   scalarLevels    // write volScalarField with cellLevel for postprocessing
   layerSets       // write cellSets, faceSets of faces in layer
   layerFields     // write volScalarField for layer coverage
);

mergeTolerance 1e-6;

